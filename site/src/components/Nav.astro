---
import { APP_URL, NAV_LINKS } from '../consts';
import logo from '../assets/logo-black.svg';
---

<nav class="flex items-center justify-between px-[14px] pt-[14px] pb-[30px]">
  <a href="/" class="flex items-center" aria-label="Trackie home">
    <img src={logo.src} alt="Trackie" class="block h-[34px] w-auto" />
  </a>
  <div class="flex items-center gap-[38px]">
    {
      NAV_LINKS.length > 0 && (
        <div class="hidden items-center gap-[34px] sm:flex">
          {NAV_LINKS.map((link) => (
            <a
              href={link.href}
              class="text-[15.5px] font-semibold text-faint no-underline"
            >
              {link.label}
            </a>
          ))}
        </div>
      )
    }
    <a
      href={APP_URL}
      class="rounded-full bg-rust px-[22px] py-[12px] text-[15.5px] font-bold whitespace-nowrap text-white no-underline"
    >
      Open Trackie
    </a>
  </div>
</nav>
