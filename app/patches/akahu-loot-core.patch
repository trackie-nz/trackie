+/*
+  post()/del() resolve to the server's response `data` (empty for our { status:
+  'ok' } replies, i.e. undefined) on success and THROW a PostError on any non-ok
+  response. The desktop-client reads these results directly - the modal checks
+  `result.error` and useBuiltInBankSyncProviders' ensureSuccessResponse reads
+  `response.error_code`/`response.error` - so a bare undefined makes the reset
+  path crash and an empty success looks like a failure. Normalise both handlers
+  to a stable shape: { status: 'ok' } on success (no error_code/error, so it
+  passes every client check) or { error } carrying the failure message.
+*/
+async function akahuSetTokens({
+  appToken,
+  userToken,
+}: {
+  appToken: string;
+  userToken: string;
+}) {
+  const sessionToken = await asyncStorage.getItem('user-token');
+
+  if (!sessionToken) {
+    return { error: 'unauthorized' };
+  }
+
+  const serverConfig = getServer();
+  if (!serverConfig) {
+    throw new Error('Failed to get server config.');
+  }
+
+  try {
+    await post(
+      serverConfig.AKAHU_SERVER + '/tokens',
+      { appToken, userToken },
+      {
+        'X-ACTUAL-TOKEN': sessionToken,
+      },
+    );
+    return { status: 'ok' };
+  } catch (error) {
+    return {
+      error: error instanceof Error ? error.message : 'Could not save tokens',
+    };
+  }
+}
+
+async function akahuClearTokens() {
+  const sessionToken = await asyncStorage.getItem('user-token');
+
+  if (!sessionToken) {
+    return { error: 'unauthorized' };
+  }
+
+  const serverConfig = getServer();
+  if (!serverConfig) {
+    throw new Error('Failed to get server config.');
+  }
+
+  try {
+    await del(
+      serverConfig.AKAHU_SERVER + '/tokens',
+      {},
+      {
+        'X-ACTUAL-TOKEN': sessionToken,
+      },
+    );
+    return { status: 'ok' };
+  } catch (error) {
+    return {
+      error: error instanceof Error ? error.message : 'Could not disconnect',
+    };
+  }
+}
