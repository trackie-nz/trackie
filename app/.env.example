# Copy to .env and fill in credentials. docker-compose / podman-compose reads .env automatically.

# Released actualbudget/actual version to build from. ONE knob drives both the
# git tag and the prebuilt Docker base image - note the leading "v" differs:
#   git checkout  v${ACTUAL_VERSION}                      (e.g. v26.6.0)
#   FROM actualbudget/actual-server:${ACTUAL_VERSION}     (e.g. 26.6.0, no "v")
# server.Dockerfile reuses that official image for the web client + node_modules,
# so the slow React compile is skipped. Bump this to the latest release tag from
# https://github.com/actualbudget/actual/releases (use the number without "v").
ACTUAL_VERSION=26.6.0

# Where to store Actual's data on the host (must be local disk - not NFS/NAS).
# Defaults to ./data (a folder next to this file) if not set.
DATA_PATH=./data

# Public URL of this server - used for OIDC and Akahu OAuth callbacks.
# Local:      http://localhost:5006
# Production: https://your-domain.example
SERVER_HOSTNAME=http://localhost:5006

# OIDC credentials. Works with any OIDC provider (Logto, Auth0, Authentik, ...).
# Register this callback URL with your provider: <SERVER_HOSTNAME>/openid/callback
# The provider MUST return a verified email claim (email + email_verified=true);
# the server rejects logins without one (see ACTUAL_IDENTITY_SECRET below).
OIDC_DISCOVERY_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Identity secret - the HMAC key used to derive each user's stored identity from
# their verified email. This is how the server avoids storing any plaintext email
# (account.sqlite holds only HMAC-SHA256(email, this secret)).
#
#   Generate once:  openssl rand -hex 32
#
# CRITICAL: back this up and NEVER change it. Rotating or losing it re-derives a
# different identity for every user, orphaning everyone from their existing budget.
# This is the single most important secret in the deployment.
ACTUAL_IDENTITY_SECRET=

# Akahu bank sync is deferred (dormant). When approved, follow
# akahu-overlay/ENABLE.md, which re-introduces the ACTUAL_AKAHU_APP_* vars here.

# ── Logto identity provider - ONLY if you run the compose.logto.yml overlay ───
# (Skip this block if you point OIDC_* above at an external provider instead.)
#
# Pin the Logto image tag - do not run :latest in production.
# Tags: https://hub.docker.com/r/svhd/logto/tags
LOGTO_TAG=
# Credentials for Logto's own Postgres (separate from Actual's data volume).
LOGTO_DB_USER=logto
LOGTO_DB_PASSWORD=
LOGTO_DB_NAME=logto
# Public https URLs Logto serves on (both behind your TLS reverse proxy).
# ENDPOINT is what users and Actual reach; ADMIN_ENDPOINT is the console.
LOGTO_ENDPOINT=https://auth.your-domain.example
LOGTO_ADMIN_ENDPOINT=https://auth-admin.your-domain.example
# Optional RSA private key (PEM) so Actual's RS256 works without a console step.
# Generate: openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:4096
# Leave BLANK to instead rotate EC -> RSA in the Logto console after first boot
# (simplest - inline multiline PEM in .env is fiddly).
LOGTO_OIDC_PRIVATE_KEY=
